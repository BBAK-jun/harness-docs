{
  "name": "@harness-docs/db",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "exports": {
    ".": "./src/index.ts"
  },
  "types": "./src/index.ts",
  "scripts": {
    "check": "tsc --noEmit -p tsconfig.json",
    "db:generate": "drizzle-kit generate --config drizzle.config.ts",
    "db:migrate": "node scripts/migrate.mjs",
    "db:studio": "drizzle-kit studio --config drizzle.config.ts --host 127.0.0.1 --port 4983"
  },
  "dependencies": {
    "drizzle-orm": "^0.44.6",
    "pg": "^8.16.3"
  },
  "devDependencies": {
    "@types/node": "^25.5.0",
    "@types/pg": "^8.15.6",
    "dotenv": "^17.2.3",
    "drizzle-kit": "^0.31.6",
    "typescript": "5.8.3"
  }
}
