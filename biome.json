{
  "$schema": "https://biomejs.dev/schemas/1.9.4/schema.json",
  "vcs": {
    "enabled": true,
    "clientKind": "git",
    "useIgnoreFile": true
  },
  "files": {
    "ignore": [
      "**/.omx/**",
      "**/.pnpm-store/**",
      "**/.vite/**",
      "**/node_modules/**",
      "**/dist/**",
      "**/target/**",
      "apps/desktop/src-tauri/gen/**",
      "apps/desktop/src/routeTree.gen.ts",
      "docs/.vitepress/**",
      "path/**",
      "scripts/.cache/**"
    ]
  },
  "formatter": {
    "indentStyle": "space",
    "lineWidth": 100
  }
}
