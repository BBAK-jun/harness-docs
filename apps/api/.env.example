PORT=4020
HOST=127.0.0.1
DATABASE_URL=postgresql://harness_docs:harness_docs@127.0.0.1:5432/harness_docs

# GitHub OAuth App credentials
GITHUB_CLIENT_ID=replace-with-github-oauth-client-id
GITHUB_CLIENT_SECRET=replace-with-github-oauth-client-secret

# Force the public API origin used to build OAuth callback URLs.
# Local example:
HARNESS_DOCS_API_BASE_URL=http://127.0.0.1:4020
# Staging example:
# HARNESS_DOCS_API_BASE_URL=https://api-staging.example.com
# Production example:
# HARNESS_DOCS_API_BASE_URL=https://api.example.com

# Optional override. Defaults to "read:user user:email".
GITHUB_OAUTH_SCOPE=read:user user:email
